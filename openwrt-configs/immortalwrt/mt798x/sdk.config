# SDK 编译配置 — 独立软件包清单
# 由 firmware_builder.yml 的 compile-packages job 在构建时读取
# 只写独立包名，INCLUDE_* 选项不要写在此文件中

# ── passwall 核心 ──
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall2=y

# ── passwall 后端依赖（INCLUDE_* 对应的实际包） ──
# passwall: INCLUDE_Xray
CONFIG_PACKAGE_xray-core=y
# passwall: INCLUDE_SingBox / passwall2: INCLUDE_SingBox
CONFIG_PACKAGE_sing-box=y
# passwall: INCLUDE_Hysteria / passwall2: INCLUDE_Hysteria
CONFIG_PACKAGE_hysteria=y
# passwall: INCLUDE_NaiveProxy / passwall2: INCLUDE_NaiveProxy
CONFIG_PACKAGE_naiveproxy=y
# passwall: INCLUDE_ShadowsocksR_Libev_Client / passwall2: 同
CONFIG_PACKAGE_shadowsocksr-libev-ssr-local=y
# passwall: INCLUDE_ShadowsocksR_Libev_Server / passwall2: 同
CONFIG_PACKAGE_shadowsocksr-libev-ssr-redir=y
# passwall: INCLUDE_Shadowsocks_Rust_Client / passwall2: 同
CONFIG_PACKAGE_shadowsocks-rust-sslocal=y
# passwall: INCLUDE_Simple_Obfs / passwall2: 同
CONFIG_PACKAGE_simple-obfs-client=y
# passwall: INCLUDE_V2ray_Plugin / passwall2: 同
CONFIG_PACKAGE_v2ray-plugin=y
# passwall: INCLUDE_Haproxy / passwall2: 同
CONFIG_PACKAGE_haproxy=y
# passwall: INCLUDE_Shadow_TLS
CONFIG_PACKAGE_shadow-tls=y
# passwall: INCLUDE_Geoview
CONFIG_PACKAGE_geoview=y
# passwall2: Basic_Core_All (tuic)
CONFIG_PACKAGE_tuic-client=y

# ── 公共工具依赖 ──
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_tcping=y

# ── 辅助工具 ──
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
