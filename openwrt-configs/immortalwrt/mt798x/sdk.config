# SDK 编译配置 — 独立软件包清单
# 由 firmware_builder.yml 的 compile-packages job 在构建时读取。
#
# ═══════ 添加软件包规则 ═══════
# 1. 只写 CONFIG_PACKAGE_<包名>=y，每行一个包。
# 2. 包名必须等于 Makefile 所在目录名（非子包名）：
#    ✅ luci-app-passwall (目录名=包名)
#    ❌ shadowsocksr-libev-ssr-local (子包，目录名是 shadowsocksr-libev)
#    多子包目录只需写一次父目录包名，所有子包会自动编译+收集。
#    例外: luci-i18n-* 列在这里会被收集，但不会传给 make（自动随父 luci app 编译）。
# 3. 需要宿主机构建工具链的包 (PKG_BUILD_DEPENDS 含 rust/host 等)
#    注释禁用（# 开头），全量编译通过 DEPS (firmware_builder.yml) 收集。
# 4. 不要写 INCLUDE_*/select 类选项（如 INCLUDE_Xray），只写实际包名。
# ════════════════════════════
#
# 内容来源: passwall + passwall2 Makefile 的 select/depends 依赖树（并集）
#   passwall:  https://github.com/Openwrt-Passwall/openwrt-passwall/blob/main/luci-app-passwall/Makefile
#   passwall2: https://github.com/Openwrt-Passwall/openwrt-passwall2/blob/main/luci-app-passwall2/Makefile
# mt798x (aarch64, ipk, iptables 透明代理)

# ── passwall 核心 ──
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall2=y

# ═══════════════════════════════════════════════════════════════
# 以下按 Makefile INCLUDE_* select 条目分组
# 注释标注了 default 值和架构条件
# ═══════════════════════════════════════════════════════════════

# ── Iptables_Transparent_Proxy (default y if !firewall4) ──
CONFIG_PACKAGE_ipt2socks=y

# ── INCLUDE_Geoview (default y if aarch64) ──
CONFIG_PACKAGE_geoview=y

# ── INCLUDE_Haproxy (default y if aarch64) ──
CONFIG_PACKAGE_haproxy=y

# ── INCLUDE_Hysteria (default n) ──
CONFIG_PACKAGE_hysteria=y

# ── INCLUDE_NaiveProxy (default n, depends on !arc,!armeb,!mips,...) ──
CONFIG_PACKAGE_naiveproxy=y

# ── INCLUDE_Shadowsocks_Rust_Client (default y if aarch64||x86_64, depends on !i386) ──
# ⚠️ SDK 不兼容: PKG_BUILD_DEPENDS:=rust/host，SDK 容器无 Rust 工具链。
#    全量固件编译可正常构建，由 DEPS (firmware_builder.yml) 收集。
# CONFIG_PACKAGE_shadowsocks-rust-sslocal=y
# CONFIG_PACKAGE_shadowsocks-rust-ssserver=y

# ── INCLUDE_ShadowsocksR_Libev_Client (default y) ──
CONFIG_PACKAGE_shadowsocksr-libev-ssr-local=y
CONFIG_PACKAGE_shadowsocksr-libev-ssr-redir=y
CONFIG_PACKAGE_shadowsocksr-libev-ssr-server=y

# ── INCLUDE_Shadow_TLS (default n, depends on aarch64||arm||x86_64) ──
# ⚠️ SDK 不兼容: PKG_BUILD_DEPENDS:=rust/host，SDK 容器无 Rust 工具链。
#    全量固件编译可正常构建，由 DEPS (firmware_builder.yml) 收集。
# CONFIG_PACKAGE_shadow-tls=y

# ── INCLUDE_Simple_Obfs (default y) ──
CONFIG_PACKAGE_simple-obfs-client=y

# ── INCLUDE_SingBox (default y if aarch64) ──
CONFIG_PACKAGE_sing-box=y

# ── INCLUDE_V2ray_Plugin (default y if aarch64) ──
CONFIG_PACKAGE_v2ray-plugin=y

# ── INCLUDE_Xray (default y if aarch64) — select xray-core + unzip ──
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_unzip=y

# INCLUDE_V2ray_Geodata (default n)
# CONFIG_PACKAGE_v2ray-geoip=y
# CONFIG_PACKAGE_v2ray-geosite=y
# INCLUDE_Xray_Plugin (default n)
# CONFIG_PACKAGE_xray-plugin=y

# ── passwall2: Basic_Core_All (tuic) ──
CONFIG_PACKAGE_tuic-client=y

# ── passwall2 LUCI_DEPENDS 硬依赖（passwall 中为可选 INCLUDE_*） ──
# passwall2 的 LUCI_DEPENDS 直接包含这些包（不通过 select），
# 并且总是需要它们（不是可选的 INCLUDE_*）。
CONFIG_PACKAGE_v2ray-geoip-full=y
CONFIG_PACKAGE_v2ray-geosite-full=y

# ═══════════════════════════════════════════════════════════════
# LUCI_DEPENDS 中的独立包 (coreutils/dnsmasq/lua/nftables 等
# 基础依赖已在固件镜像中, 不需要 SDK 单独编译)
# 以下是从 LUCI_DEPENDS 提取的、不常在固件中的独立包
# ═══════════════════════════════════════════════════════════════
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_tcping=y

# ── 辅助工具 ──
# 注意: luci-i18n-* 包无法独立 make (目录属于父 luci app)，
# 但应在此列出以被 collect 步骤收集。resolve-pkgs 会自动过滤不传给 make。
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
