+msgstr "以首个应答为准。"
+
+#: modules/luci-mod-network/htdocs/luci-static/resources/view/network/dhcp.js:389
+msgid "Cache"
+msgstr "缓存"
+
+#: modules/luci-mod-network/htdocs/luci-static/resources/view/network/dhcp.js:404
